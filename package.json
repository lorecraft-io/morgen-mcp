{
  "name": "fidgetcoding-morgen-mcp",
  "version": "0.1.14",
  "description": "MCP server for Morgen — events, tasks, and calendar management for Claude Code via natural language",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "morgen-mcp": "src/index.js"
  },
  "files": [
    "src/",
    "bin/",
    ".env.example",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "start": "node src/index.js",
    "setup": "node bin/setup.js",
    "test": "vitest run",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "mcp",
    "morgen",
    "calendar",
    "tasks",
    "claude",
    "ai",
    "productivity",
    "scheduling"
  ],
  "author": "Nate Davidovich <nate@lorecraft.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lorecraft-io/morgen-mcp.git"
  },
  "homepage": "https://github.com/lorecraft-io/morgen-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "chrono-node": "^2.9.0",
    "dotenv": "17.4.2"
  },
  "devDependencies": {
    "vitest": "4.1.2"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.0.0-rc.15",
    "@rolldown/binding-linux-arm64-gnu": "1.0.0-rc.15",
    "@rolldown/binding-darwin-arm64": "1.0.0-rc.15",
    "@rolldown/binding-darwin-x64": "1.0.0-rc.17"
  },
  "bugs": {
    "url": "https://github.com/lorecraft-io/morgen-mcp/issues"
  }
}
